rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper to check if user is signed in
    function isSignedIn() {
      return request.auth != null;
    }

    // Helper to check if user is an admin based on their user document
    function isAdmin() {
      return isSignedIn() &&
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // User profiles: Users can read/write their own; Admins can read all.
    match /users/{userId} {
      allow read: if isSignedIn() && (request.auth.uid == userId || isAdmin());
      allow write: if isSignedIn() && (request.auth.uid == userId || isAdmin());
    }

    // Deals:
    // - Authenticated users can create deals.
    // - Freelancers and Clients can read/update deals they are involved in (via email).
    // - Admins can read, update, and delete all deals.
    match /deals/{dealId} {
      allow read: if isSignedIn() && (
        request.auth.token.email == resource.data.freelancerEmail ||
        request.auth.token.email == resource.data.clientEmail ||
        isAdmin()
      );

      allow create: if isSignedIn();

      allow update: if isSignedIn() && (
        request.auth.token.email == resource.data.freelancerEmail ||
        request.auth.token.email == resource.data.clientEmail ||
        isAdmin()
      );

      allow delete: if isAdmin();
    }
  }
}
